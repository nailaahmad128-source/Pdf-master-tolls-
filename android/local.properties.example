# Copy this file to `local.properties` (same folder) and fill in the paths
# for YOUR machine. Android Studio / `flutter create` normally generate
# this automatically the first time you open or build the project -- it
# is intentionally NOT committed to version control since the paths are
# machine-specific.

sdk.dir=/Users/yourname/Library/Android/sdk
flutter.sdk=/Users/yourname/development/flutter
flutter.versionName=1.0.0
flutter.versionCode=1
